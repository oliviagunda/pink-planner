{
  "manifest_version": 3,
  "name": "My Pretty Todo ✨",
  "version": "1.0",
  "description": "A girly, notebook-style todo list with daily motivational quotes",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"]
}
